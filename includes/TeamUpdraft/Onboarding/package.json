{
    "name": "@burst-statistics/burst-onboarding",
    "version": "1.0.0",
    "description": "Team Updraft Onboarding App",
    "scripts": {
        "build": "wp-scripts build && npm run build:css",
        "build:css": "postcss ./src/styles/tailwind.css -o ./build/index.css",
        "watch:css": "postcss ./src/styles/tailwind.css -o ./build/index.css --watch",
        "start:js": "wp-scripts start",
        "start": "npm-run-all --parallel start:js watch:css",
        "lint:js": "wp-scripts lint-js",
        "lint:style": "wp-scripts lint-style",
        "packages-update": "wp-scripts packages-update --dist-tag=wp-6.2"
    },
    "dependencies": {
        "@radix-ui/react-checkbox": "^1.3.1",
        "@radix-ui/react-dialog": "^1.1.6",
        "@radix-ui/react-label": "^2.1.4",
        "@radix-ui/react-switch": "^1.2.1",
        "@radix-ui/react-tooltip": "^1.2.6",
        "@radix-ui/react-visually-hidden": "^1.2.3",
        "@wordpress/element": "^5.3.3",
        "@wordpress/i18n": "^4.26.2",
        "clsx": "^2.1.1",
        "lucide-react": "^0.510.0",
        "react-confetti-explosion": "^3.0.3",
        "zustand": "^4.5.0"
    },
    "devDependencies": {
        "@tailwindcss/postcss": "^4.2.2",
        "@wordpress/scripts": "^25.3.6",
        "npm-run-all": "^4.1.5",
        "postcss": "^8.4.35",
        "postcss-cli": "^11.0.1",
        "tailwindcss": "^4.2.2"
    }
}
